# Postgres (matches PROVIDER_ENGAGEMENT_SERVICE_POSTGRES__* env vars in k8s/deployment.yaml)
PROVIDER_ENGAGEMENT_SERVICE_POSTGRES__HOST=localhost
PROVIDER_ENGAGEMENT_SERVICE_POSTGRES__PORT=5432
PROVIDER_ENGAGEMENT_SERVICE_POSTGRES__NAME=provider_engagement_service_db
PROVIDER_ENGAGEMENT_SERVICE_POSTGRES__USERNAME=provider_engagement_service
PROVIDER_ENGAGEMENT_SERVICE_POSTGRES__PASSWORD=postgres
PROVIDER_ENGAGEMENT_SERVICE_POSTGRES__REQUIRE_SSL=false
PROVIDER_ENGAGEMENT_SERVICE_POSTGRES__POOL_SIZE=40
PROVIDER_ENGAGEMENT_SERVICE_POSTGRES__MAX_OVERFLOW=20
PROVIDER_ENGAGEMENT_SERVICE_POSTGRES__POOL_TIMEOUT=3
PROVIDER_ENGAGEMENT_SERVICE_POSTGRES__POOL_RECYCLE_SECONDS=3600
PROVIDER_ENGAGEMENT_SERVICE_POSTGRES__POOL_PRE_PING=true

# SNS publishing
PROVIDER_ENGAGEMENT_SERVICE_SNS_CLIENT__REGION_NAME=us-east-1
PROVIDER_ENGAGEMENT_SERVICE_SNS_PUBLISHING__INTERNAL_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:test-provider-engagement-internal-topic
PROVIDER_ENGAGEMENT_SERVICE_SNS_PUBLISHING__PUBLIC_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:test-events-topic
PROVIDER_ENGAGEMENT_SERVICE_SNS_PUBLISHING__PUBSUB_MESSAGE_URI_HOST=https://provider-engagement.local

# AWS creds (set anything for local; boto3 just needs values to skip STS)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
